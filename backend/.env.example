# ─────────────────────────────────────────────────────────────────
# CricketIQ — Backend Environment Variables Template
# Copy to .env:  cp backend/.env.example backend/.env
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# Async URL (used by FastAPI / SQLAlchemy async engine)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/cricketiq

# Sync URL (used by data pipeline scripts and Alembic migrations)
DATABASE_URL_SYNC=postgresql://USER:PASSWORD@HOST:5432/cricketiq

# ── Data Paths ────────────────────────────────────────────────────
# Absolute or relative path to the processed parquet files.
# Defaults to ./data/processed relative to project root.
DATA_PATH=data/processed

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# ── API ───────────────────────────────────────────────────────────
PORT=8000
WORKERS=2
LOG_LEVEL=info
DEBUG=false

# ── Cricsheet Download URLs ───────────────────────────────────────
CRICSHEET_IPL_URL=https://cricsheet.org/downloads/ipl_json.zip
CRICSHEET_T20I_URL=https://cricsheet.org/downloads/t20s_json.zip
