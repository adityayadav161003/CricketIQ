# ─────────────────────────────────────────────
# CricketIQ — Environment Variables Template
# Copy to .env and fill your values:
#   cp .env.example .env
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_ENV=development
APP_NAME=CricketIQ
API_VERSION=v1
DEBUG=true

# ── Database (PostgreSQL via Supabase) ───────
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/cricketiq
DATABASE_URL_SYNC=postgresql://USER:PASSWORD@HOST:5432/cricketiq

# ── Cricsheet Data ────────────────────────────
CRICSHEET_IPL_URL=https://cricsheet.org/downloads/ipl_json.zip
CRICSHEET_T20I_URL=https://cricsheet.org/downloads/t20s_json.zip

# ── Paths ─────────────────────────────────────
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed

# ── Backend ───────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,https://cricketiq.vercel.app

# ── Frontend (Next.js) ────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
